{
  "defs": {
    "main": {
      "type": "procedure",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "properties": {
            "displayName": {
              "type": "string"
            },
            "avatar": {
              "type": "string",
              "description": "An 'image/png' or 'image/jpeg' encoded as a base64 data URL"
            }
          },
          "nullable": [
            "displayName",
            "avatar"
          ]
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "fish.msg.duc.actor.profile"
        }
      },
      "errors": [
        {
          "name": "invalidAvatarData"
        },
        {
          "name": "avatarUploadFailed"
        },
        {
          "name": "profileUpdateFailed"
        }
      ]
    }
  },
  "id": "fish.msg.duc.users.updateProfile",
  "lexicon": 1
}