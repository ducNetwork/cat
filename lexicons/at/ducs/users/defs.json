{
  "defs": {
    "profile": {
      "type": "object",
      "properties": {
        "did": {
          "type": "string",
          "format": "did"
        },
        "handle": {
          "type": "string",
          "format": "handle"
        },
        "displayName": {
          "type": "string"
        },
        "avatar": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "did",
        "handle"
      ]
    },
    "avatar": {
      "type": "blob",
      "accept": [
        "image/png",
        "image/jpeg"
      ],
      "maxSize": 1000000,
      "description": "Image to be displayed next to messages from a user"
    }
  },
  "id": "at.ducs.users.defs",
  "lexicon": 1
}