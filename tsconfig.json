{
  "compilerOptions": {
    "types": ["node", "bun"],
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "@lib": ["./src/lib"],
      "@lib/*": ["./src/lib/*"],

      "@lexicons": ["./generated/lexicons"],
      "@lexicons/*": ["./generated/lexicons/*"]
    },
    "outDir": "build",
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
  ]
}